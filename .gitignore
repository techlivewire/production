# ============================================================
# .gitignore — Sustainable Business Union
# ============================================================

# ── Environment & Secrets ────────────────────────────────────
.env
.env.local
.env.development
.env.production
.env.staging
*.pem
*.key
*.cert

# ── Dependencies ─────────────────────────────────────────────
node_modules/
.npm
.yarn/
yarn.lock

# ── User Uploads ─────────────────────────────────────────────
public/uploads/
uploads/

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ── Build / Cache ────────────────────────────────────────────
dist/
build/
.cache/
.parcel-cache/
.tmp/
tmp/

# ── OS Files ─────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
Thumbs.db
Desktop.ini

# ── Editor & IDE ─────────────────────────────────────────────
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
*.swp

# ── Old / Backup Files ───────────────────────────────────────
server1.js
*.bak
*.backup
*.orig