<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Order Form | Sustainable Business Union</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="/css/contact.css">
</head>
<body>

<div class="form-page">

  <div class="form-container">

    <a href="/" class="back-link">← Back to Home</a>

    <h1 class="form-title">ORDER FORM - LONDON MONTHLY CONNECT</h1>

    <p class="form-subtext">
      Thank you for registering for a Sustainable Business Union Connect event.
      Please fill out this form to request entry.  
      <br><br>
      📞 +44-7770-264-192 | ✉ info@sustainablebusinessunion.com
    </p>

    <form class="contact-form" method="POST" action="/submitForm">

      <!-- WHAT ARE YOU LOOKING FOR -->
      <label>What are you looking for?</label>
      <div class="radio-group">
        <label><input type="radio" name="type"> Investor looking for startups</label>
        <label><input type="radio" name="type"> Startup looking for investors</label>
        <label><input type="radio" name="type"> Industry expert networking</label>
        <label><input type="radio" name="type"> Other</label>
      </div>

      <!-- COMPANY -->
      <label>Company Name *</label>
      <input type="text" name="company" required>

      <!-- WEBSITE -->
      <label>Website *</label>
      <input type="url" name="website" required>

      <!-- LINKEDIN -->
      <label>LinkedIn Profile</label>
      <input type="url" name="linkedin">

      <!-- SLOT -->
      <label>One-minute pitch slot?</label>
      <select name="slot">
        <option>Yes</option>
        <option>No</option>
      </select>

      <!-- CONTACT INFO -->
      <h3>Contact Info</h3>

      <label>Your Name *</label>
      <input type="text" name="name" required>

      <label>Phone Number *</label>
      <input type="tel" name="phone" required>

      <label>Email</label>
      <input type="email" name="email">

      <!-- CONTACT METHOD -->
      <label>Preferred Contact Method *</label>
      <div class="radio-group">
        <label><input type="radio" name="contactMethod" required> Phone</label>
        <label><input type="radio" name="contactMethod"> Email</label>
      </div>

      <!-- CONSENT -->
      <div class="consent">
        <input type="checkbox" required>
        <span>
          I consent to photography, recordings, and sharing my details for networking purposes.
        </span>
      </div>

      <button type="submit" class="submit-btn">Submit</button>

    </form>

  </div>

</div>

</body>
</html>