<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Access Denied</title>

<link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:'Poppins',sans-serif;
}

body{
    min-height:100vh;
    display:flex;
    justify-content:center;
    align-items:center;
    background:linear-gradient(135deg,#0f172a,#1e293b);
    color:#fff;
    padding:20px;
}

.container{
    max-width:650px;
    width:100%;
    text-align:center;
    background:rgba(255,255,255,0.05);
    backdrop-filter:blur(15px);
    border:1px solid rgba(255,255,255,0.1);
    border-radius:24px;
    padding:50px 40px;
    box-shadow:0 20px 60px rgba(0,0,0,0.4);
}

.lock{
    font-size:90px;
    margin-bottom:20px;
}

.code{
    font-size:90px;
    font-weight:700;
    color:#ef4444;
    line-height:1;
}

h1{
    margin-top:15px;
    font-size:32px;
    font-weight:600;
}

p{
    margin-top:15px;
    color:#cbd5e1;
    line-height:1.8;
    font-size:16px;
}

.actions{
    margin-top:35px;
    display:flex;
    justify-content:center;
    gap:15px;
    flex-wrap:wrap;
}

.btn{
    text-decoration:none;
    padding:14px 28px;
    border-radius:12px;
    font-weight:600;
    transition:.3s;
}

.btn-home{
    background:#2563eb;
    color:white;
}

.btn-home:hover{
    transform:translateY(-2px);
}

.btn-login{
    background:#ef4444;
    color:white;
}

.btn-login:hover{
    transform:translateY(-2px);
}

.footer{
    margin-top:30px;
    font-size:13px;
    color:#94a3b8;
}
</style>
</head>
<body>

<div class="container">

    <div class="lock">🔒</div>

    <div class="code">403</div>

    <h1>Access Denied</h1>

    <p>
        You do not have permission to access this administration area.
        If you believe this is a mistake, please contact the system administrator.
    </p>

    <div class="actions">
        <a href="/" class="btn btn-home">Return Home</a>
        <a href="/login" class="btn btn-login">Login</a>
    </div>

    <div class="footer">
        Sustainable Business Union • Secure Administration Portal
    </div>

</div>

</body>
</html>