<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Sign In – Sustainable Business Union</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', sans-serif;
      background: #f5f0e8;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }

    .auth-wrap {
      display: grid;
      grid-template-columns: 1fr 1fr;
      max-width: 800px;
      width: 100%;
      background: #fff;
      border-radius: 16px;
      overflow: hidden;
      box-shadow: 0 8px 40px rgba(0,0,0,.1);
    }
    @media(max-width:580px){ .auth-wrap { grid-template-columns: 1fr; } }

    /* Left */
    .auth-left {
      background: #1c1430;
      padding: 3rem 2.5rem;
      display: flex;
      flex-direction: column;
      justify-content: center;
      color: #fff;
    }
    @media(max-width:580px){ .auth-left { display: none; } }

    .auth-left .logo { font-size: 1.3rem; font-weight: 700; margin-bottom: 2rem; }
    .auth-left .logo span { color: #e8701a; }
    .auth-left h2 { font-size: 1.5rem; font-weight: 700; line-height: 1.3; margin-bottom: .85rem; }
    .auth-left p  { font-size: .85rem; color: rgba(255,255,255,.55); line-height: 1.7; margin-bottom: 1.75rem; }

    .back-home {
      display: inline-flex;
      align-items: center;
      gap: .4rem;
      color: rgba(255,255,255,.5);
      text-decoration: none;
      font-size: .8rem;
      transition: color .2s;
    }
    .back-home:hover { color: #e8701a; }

    /* Right */
    .auth-right { padding: 3rem 2.5rem; }

    .auth-right h1 {
      font-size: 1.4rem;
      font-weight: 700;
      color: #1c1430;
      margin-bottom: .3rem;
    }
    .auth-right .subtitle {
      font-size: .83rem;
      color: #888;
      margin-bottom: 1.75rem;
    }
    .auth-right .subtitle a { color: #e8701a; text-decoration: none; font-weight: 500; }

    .error-box {
      background: #ffebee;
      border: 1px solid #ffcdd2;
      border-radius: 8px;
      padding: .65rem .9rem;
      font-size: .82rem;
      color: #c62828;
      margin-bottom: 1.25rem;
    }

    .fg { display: flex; flex-direction: column; gap: .3rem; margin-bottom: .85rem; }
    .fg label {
      font-size: .74rem;
      letter-spacing: .06em;
      text-transform: uppercase;
      color: #888;
      font-weight: 600;
    }
    .fg input {
      padding: .65rem .85rem;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-family: 'Inter', sans-serif;
      font-size: .88rem;
      color: #1c1430;
      background: #fafafa;
      transition: border-color .2s;
    }
    .fg input:focus { outline: none; border-color: #1c1430; background: #fff; }

    .btn-login {
      width: 100%;
      padding: .75rem;
      background: #1c1430;
      color: #fff;
      border: none;
      border-radius: 8px;
      font-family: 'Inter', sans-serif;
      font-size: .92rem;
      font-weight: 600;
      cursor: pointer;
      transition: background .2s;
      margin-top: .5rem;
    }
    .btn-login:hover { background: #e8701a; }

    .signup-link {
      text-align: center;
      margin-top: 1.25rem;
      font-size: .82rem;
      color: #888;
    }
    .signup-link a { color: #1c1430; font-weight: 600; text-decoration: none; }
    .signup-link a:hover { color: #e8701a; }
  </style>
</head>
<body>

<div class="auth-wrap">

  <!-- Left -->
  <div class="auth-left">
    <div class="logo">SB<span>U</span></div>
    <h2>Welcome back</h2>
    <p>Sign in to your Sustainable Business Union account to access events, resources and community updates.</p>
    <a href="/" class="back-home">← Back to home</a>
  </div>

  <!-- Right -->
  <div class="auth-right">
    <h1>Sign In</h1>
    <p class="subtitle">Don't have an account? <a href="/signup">Sign up free</a></p>

    <% if (error) { %>
      <div class="error-box">⚠️ <%= error %></div>
    <% } %>

    <form method="POST" action="/login">

      <div class="fg">
        <label>Email Address</label>
        <input type="email" name="email" placeholder="you@example.com" required autofocus>
      </div>

      <div class="fg">
        <label>Password</label>
        <input type="password" name="password" placeholder="Your password" required>
      </div>

      <button type="submit" class="btn-login">Sign In →</button>
    </form>

    <div class="signup-link">
      New here? <a href="/signup">Create an account</a>
    </div>
  </div>

</div>

</body>
</html>
