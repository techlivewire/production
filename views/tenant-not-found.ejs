<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Tenant Not Found</title>
  <link rel="stylesheet" href="/css/style.css">
  <style>
    .tnf-container {
      height: 100vh;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      font-family: Arial, sans-serif;
      text-align: center;
    }

    .tnf-container h1 {
      font-size: 32px;
      margin-bottom: 10px;
      color: #333;
    }

    .tnf-container p {
      font-size: 16px;
      color: #666;
      margin-bottom: 20px;
    }

    .tnf-container a {
      text-decoration: none;
      background: #007bff;
      color: white;
      padding: 8px 16px;
      border-radius: 4px;
      transition: 0.2s ease;
    }

    .tnf-container a:hover {
      background: #0056b3;
    }
  </style>
</head>
<body>

  <div class="tnf-container">
    <h1>Tenant Not Found</h1>
    <p>The requested tenant does not exist or may have been removed.</p>
    <a href="/">Go to Home</a>
  </div>

</body>
</html>