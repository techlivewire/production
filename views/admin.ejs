  <h2>Manage Pages</h2>
  <form action="/updatePage" method="POST">
    <select name="name">
      <option value="privacy">Privacy Policy</option>
      <option value="terms">Terms & Conditions</option>
    </select>
    <textarea name="content" rows="10" placeholder="Enter full HTML content..." required style="width:100%;margin-top:.75rem;padding:.5rem;font-family:monospace;font-size:.82rem"></textarea>
    <button type="submit" style="margin-top:.75rem">Save Page</button>
  </form>
</div> -->



    </main>
  </div>

</body>
</html>
