<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Bulk Import & Mass Delete – eLibrary Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    /* ── Matches your existing admin style exactly ── */

    .page-topbar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1.5rem;
    }

    .section-label {
      font-size: .72rem;
      letter-spacing: .1em;
      text-transform: uppercase;
      color: #999;
      font-weight: 600;
      margin-bottom: 1rem;
      padding-bottom: .5rem;
      border-bottom: 1px solid #eee;
    }

    /* Upload boxes */
    .upload-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
      margin-bottom: 1.25rem;
    }
    @media(max-width:640px){ .upload-grid { grid-template-columns: 1fr; } }

    .upload-box {
      border: 2px dashed #ddd;
      border-radius: 10px;
      padding: 1.75rem 1rem;
      text-align: center;
      cursor: pointer;
      position: relative;
      transition: border-color .2s, background .2s;
      background: #fafafa;
    }
    .upload-box:hover { border-color: #1c1430; background: #f5f0e8; }
    .upload-box.filled { border-color: #2e7d32; border-style: solid; background: #f1f8e9; }
    .upload-box input[type="file"] {
      position: absolute; inset: 0;
      width: 100%; height: 100%;
      opacity: 0; cursor: pointer;
    }
    .upload-box .ub-icon  { font-size: 2rem; margin-bottom: .5rem; }
    .upload-box .ub-label { font-size: .88rem; font-weight: 600; color: #333; margin-bottom: .2rem; }
    .upload-box .ub-hint  { font-size: .75rem; color: #aaa; }
    .upload-box .ub-name  { font-size: .8rem; color: #2e7d32; font-weight: 600; margin-top: .5rem; display: none; }

    /* Buttons matching your style */
    .btn-import {
      padding: .55rem 1.4rem;
      background: #1c1430;
      color: #fff;
      border: none;
      border-radius: 7px;
      font-size: .88rem;
      font-weight: 600;
      cursor: pointer;
      text-decoration: none;
      transition: background .2s;
      display: inline-flex;
      align-items: center;
      gap: .5rem;
      font-family: inherit;
    }
    .btn-import:hover { background: #e8701a; }
    .btn-import:disabled { opacity: .5; cursor: not-allowed; }

    .btn-tpl {
      padding: .55rem 1.1rem;
      background: #fff;
      color: #555;
      border: 1px solid #ddd;
      border-radius: 7px;
      font-size: .85rem;
      cursor: pointer;
      text-decoration: none;
      font-family: inherit;
      transition: background .2s;
    }
    .btn-tpl:hover { background: #f5f0e8; color: #333; }

    /* Spinner */
    .spinner {
      width: 14px; height: 14px;
      border: 2px solid rgba(255,255,255,.35);
      border-top-color: #fff;
      border-radius: 50%;
      animation: spin .7s linear infinite;
      display: none;
    }
    @keyframes spin { to { transform: rotate(360deg); } }

    /* Result */
    .result-box {
      margin-top: 1.25rem;
      border: 1px solid #eee;
      border-radius: 10px;
      overflow: hidden;
    }
    .result-top {
      display: flex; align-items: center; gap: .65rem;
      padding: .85rem 1.1rem;
    }
    .result-top.ok   { background: #e8f5e9; border-bottom: 1px solid #c8e6c9; }
    .result-top.fail { background: #ffebee; border-bottom: 1px solid #ffcdd2; }
    .result-top h3   { font-size: .9rem; font-weight: 700; color: #333; }

    .stat-chips {
      display: flex; gap: .5rem; flex-wrap: wrap;
      padding: .75rem 1.1rem; background: #fafafa;
      border-bottom: 1px solid #eee;
    }
    .stat-chip {
      padding: .25rem .7rem; border-radius: 20px;
      font-size: .78rem; font-weight: 600;
    }
    .chip-blue   { background: #e3f2fd; color: #1565c0; }
    .chip-green  { background: #e8f5e9; color: #2e7d32; }
    .chip-orange { background: #fff3e0; color: #e65100; }
    .chip-red    { background: #ffebee; color: #c62828; }

    .log-scroll { max-height: 300px; overflow: auto; }
    .log-table  { width: 100%; border-collapse: collapse; font-size: .8rem; }
    .log-table th {
      background: #f5f0e8; padding: .5rem .85rem;
      text-align: left; font-size: .7rem;
      letter-spacing: .08em; text-transform: uppercase; color: #666;
      border-bottom: 2px solid #e8dcc8;
      position: sticky; top: 0;
    }
    .log-table td { padding: .48rem .85rem; border-bottom: 1px solid #eee; color: #444; }
    .t-ok    { color: #2e7d32; font-weight: 600; }
    .t-skip  { color: #e65100; }
    .t-warn  { color: #d4a017; }
    .t-error { color: #c62828; font-weight: 600; }

    /* Mass delete */
    .filter-bar {
      display: flex; gap: .6rem; flex-wrap: wrap;
      align-items: flex-end; margin-bottom: 1rem;
    }
    .filter-bar .fg { display: flex; flex-direction: column; gap: .25rem; }
    .filter-bar label { font-size: .72rem; letter-spacing: .08em; text-transform: uppercase; color: #999; font-weight: 600; }
    .filter-bar select,
    .filter-bar input {
      padding: .45rem .75rem;
      border: 1px solid #ddd;
      border-radius: 7px;
      font-size: .83rem;
      color: #333;
      background: #fff;
      font-family: inherit;
    }
    .filter-bar select:focus,
    .filter-bar input:focus { outline: none; border-color: #1c1430; }

    .select-bar {
      display: none;
      align-items: center; gap: .75rem;
      padding: .6rem 1rem;
      background: #fff3e0;
      border: 1px solid #ffe0b2;
      border-radius: 7px;
      margin-bottom: 1rem;
      flex-wrap: wrap;
    }
    .select-bar.visible { display: flex; }
    .select-count { font-size: .85rem; font-weight: 700; color: #e65100; }

    .table-wrap {
      border: 1px solid #eee;
      border-radius: 8px;
      overflow: auto;
      max-height: 400px;
    }

    /* Reuse your existing .eli-table styles */
    .eli-table th { position: sticky; top: 0; z-index: 1; }

    .bottom-bar {
      display: flex; justify-content: space-between;
      align-items: center; flex-wrap: wrap;
      gap: .5rem; margin-top: .75rem;
    }
    .bottom-bar span { font-size: .8rem; color: #888; }
    .pag-controls { display: flex; gap: .4rem; align-items: center; }

    /* Delete confirm modal */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.45); z-index: 1000;
      align-items: center; justify-content: center;
    }
    .modal-overlay.show { display: flex; }
    .modal-box {
      background: #fff;
      border-radius: 12px;
      padding: 2rem 1.75rem;
      max-width: 380px; width: 90%;
      text-align: center;
      box-shadow: 0 16px 48px rgba(0,0,0,.18);
    }
    .modal-box .m-icon { font-size: 2.5rem; margin-bottom: .6rem; }
    .modal-box h3 { font-size: 1rem; font-weight: 700; color: #c62828; margin-bottom: .4rem; }
    .modal-box p  { font-size: .83rem; color: #666; margin-bottom: 1.25rem; line-height: 1.5; }
    .modal-btns { display: flex; gap: .65rem; justify-content: center; }

    .empty-note { text-align: center; padding: 2.5rem; color: #aaa; font-size: .85rem; font-style: italic; }

    /* Toast */
    .toast {
      position: fixed; bottom: 1.75rem; right: 1.75rem;
      padding: .7rem 1.2rem; border-radius: 8px;
      font-size: .85rem; font-weight: 600; color: #fff;
      z-index: 9999; opacity: 1;
      transition: opacity .3s;
      box-shadow: 0 4px 16px rgba(0,0,0,.15);
    }
  </style>
</head>
<body>
<div class="app">
  <aside class="sidebar">
    <h2>Admin Panel</h2>
    <nav>
      <a href="/admin">Dashboard</a>
      <a href="/admin/library">Library</a>
      <a href="/admin/elibrary" class="active">eLibrary</a>
    </nav>
  </aside>

  <main class="main">
    <header class="header"><h1>Bulk Import & Mass Delete</h1></header>

    <!-- ── IMPORT ─────────────────────────────────────────────────────────── -->
    <section class="card">
      <div class="page-topbar">
        <div>
          <h2>Bulk Import</h2>
          <p style="font-size:.82rem;color:#888;margin-top:.2rem">Upload an Excel sheet + ZIP of PDFs to import multiple items at once</p>
        </div>
        <div style="display:flex;gap:.5rem">
          <a href="/elibrary-template.xlsx" download class="btn-tpl">⬇ Download Template</a>
          <a href="/admin/elibrary" class="btn-tpl">← Back</a>
        </div>
      </div>

      <div class="section-label">Step 1 — Select your files</div>

      <form method="POST" action="/admin/elibrary/import" enctype="multipart/form-data" id="importForm">
        <div class="upload-grid">

          <div class="upload-box" id="excelBox">
            <input type="file" name="excel" accept=".xlsx,.xls" id="excelInput" required>
            <div class="ub-icon">📊</div>
            <div class="ub-label">Click to select Excel file</div>
            <div class="ub-hint">.xlsx or .xls — one item per row</div>
            <div class="ub-name" id="excelName"></div>
          </div>

          <div class="upload-box" id="zipBox">
            <input type="file" name="zip" accept=".zip" id="zipInput" required>
            <div class="ub-icon">🗜️</div>
            <div class="ub-label">Click to select ZIP of PDFs</div>
            <div class="ub-hint">.zip — all PDFs flat inside, no subfolders</div>
            <div class="ub-name" id="zipName"></div>
          </div>

        </div>

        <div class="section-label">Step 2 — Import</div>
        <div style="display:flex;align-items:center;gap:.75rem;flex-wrap:wrap">
          <button type="submit" class="btn-import" id="importBtn">
            <span id="importBtnText">Import Now</span>
            <span class="spinner" id="importSpinner"></span>
          </button>
          <span style="font-size:.75rem;color:#aaa">Required Excel columns: <strong>title</strong>, <strong>libraryType</strong></span>
        </div>
      </form>

      <!-- Result -->
      <% if (result) { %>
        <% if (!result.success) { %>
          <div class="result-box">
            <div class="result-top fail">
              <span>❌</span><h3>Import Failed — <%= result.error %></h3>
            </div>
          </div>
        <% } else { %>
          <div class="result-box">
            <div class="result-top ok">
              <span>✅</span><h3>Import Complete</h3>
            </div>
            <div class="stat-chips">
              <span class="stat-chip chip-blue">📦 <%= result.extracted %> files from ZIP</span>
              <span class="stat-chip chip-blue">📊 <%= result.total %> rows in Excel</span>
              <span class="stat-chip chip-green">✅ <%= result.inserted %> imported</span>
              <span class="stat-chip chip-orange">⏭️ <%= result.skipped %> skipped</span>
              <span class="stat-chip chip-red">❌ <%= result.errors %> errors</span>
            </div>
            <div class="log-scroll">
              <table class="log-table">
                <thead>
                  <tr><th>Row</th><th>Status</th><th>Title</th><th>Message</th></tr>
                </thead>
                <tbody>
                  <% result.log.forEach(e => { %>
                  <tr>
                    <td><%= e.row %></td>
                    <td>
                      <% if(e.type==='ok')    { %><span class="t-ok">✅ OK</span><% } %>
                      <% if(e.type==='skip')  { %><span class="t-skip">⏭️ Skipped</span><% } %>
                      <% if(e.type==='warn')  { %><span class="t-warn">⚠️ Warning</span><% } %>
                      <% if(e.type==='error') { %><span class="t-error">❌ Error</span><% } %>
                    </td>
                    <td><%= e.title %></td>
                    <td class="t-<%= e.type %>"><%= e.msg %></td>
                  </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <div style="padding:.85rem 1.1rem;display:flex;gap:.5rem">
              <a href="/admin/elibrary" class="btn-import" style="font-size:.83rem;padding:.45rem 1rem">View All Items →</a>
              <a href="/elibrary" target="_blank" class="btn-tpl">View Public ↗</a>
            </div>
          </div>
        <% } %>
      <% } %>
    </section>

    <!-- ── MASS DELETE ────────────────────────────────────────────────────── -->
    <section class="card" style="margin-top:1.5rem">
      <div class="page-topbar">
        <div>
          <h2>Mass Delete</h2>
          <p style="font-size:.82rem;color:#888;margin-top:.2rem">Select items using checkboxes then delete in bulk</p>
        </div>
      </div>

      <!-- Filters -->
      <div class="filter-bar">
        <div class="fg">
          <label>Type</label>
          <select id="filterType">
            <option value="">All Types</option>
            <option value="spiritual">Spiritual</option>
            <option value="basic">Basic</option>
          </select>
        </div>
        <div class="fg">
          <label>Search Title</label>
          <input type="text" id="filterTitle" placeholder="Search title…" style="width:200px">
        </div>
        <button type="button" class="btn-import" style="padding:.45rem 1rem;font-size:.83rem" onclick="applyFilter()">Filter</button>
        <button type="button" class="btn-tpl" onclick="resetFilter()">Reset</button>
      </div>

      <!-- Selection bar -->
      <div class="select-bar" id="selectBar">
        <span class="select-count" id="selectCount">0 selected</span>
        <button type="button" class="btn-delete" onclick="showConfirm()">🗑️ Delete Selected</button>
        <button type="button" class="btn-tpl" onclick="clearSelection()">Clear Selection</button>
      </div>

      <!-- Table -->
      <div class="table-wrap">
        <table class="eli-table" id="itemsTable">
          <thead>
            <tr>
              <th style="width:36px"><input type="checkbox" id="checkAll" onclick="toggleAll(this)"></th>
              <th>Title</th>
              <th>Type</th>
              <th>Author</th>
              <th>Availability</th>
              <th>Added</th>
            </tr>
          </thead>
          <tbody id="itemsBody">
            <tr><td colspan="6" class="empty-note">Loading…</td></tr>
          </tbody>
        </table>
      </div>

      <div class="bottom-bar">
        <span id="totalCount"></span>
        <div class="pag-controls">
          <a class="pag-btn disabled" id="prevBtn" onclick="changePage(-1)">‹ Prev</a>
          <span id="pageInfo" style="font-size:.82rem;color:#888"></span>
          <a class="pag-btn" id="nextBtn" onclick="changePage(1)">Next ›</a>
        </div>
      </div>
    </section>

    <!-- Confirm modal -->
    <div class="modal-overlay" id="confirmModal">
      <div class="modal-box">
        <div class="m-icon">⚠️</div>
        <h3>Confirm Delete</h3>
        <p id="confirmText">This will permanently delete the selected items. This cannot be undone.</p>
        <div class="modal-btns">
          <button class="btn-delete" id="confirmBtn" onclick="executeDelete()">Yes, Delete</button>
          <button class="btn-tpl" onclick="hideConfirm()">Cancel</button>
        </div>
      </div>
    </div>

  </main>
</div>

<script>
// ── Import form ───────────────────────────────────────────────────────────────
function setupPicker(inputId, boxId, nameId) {
  document.getElementById(inputId).addEventListener("change", function() {
    if (this.files[0]) {
      const nameEl = document.getElementById(nameId);
      nameEl.textContent = "✅ " + this.files[0].name;
      nameEl.style.display = "block";
      document.getElementById(boxId).classList.add("filled");
    }
  });
}
setupPicker("excelInput", "excelBox", "excelName");
setupPicker("zipInput",   "zipBox",   "zipName");

document.getElementById("importForm").addEventListener("submit", function() {
  const btn     = document.getElementById("importBtn");
  const txt     = document.getElementById("importBtnText");
  const spinner = document.getElementById("importSpinner");
  btn.disabled          = true;
  txt.textContent       = "Importing…";
  spinner.style.display = "inline-block";
});

// ── Mass delete ───────────────────────────────────────────────────────────────
let allItems    = [];
let filtered    = [];
let currentPage = 1;
const PER_PAGE  = 20;
let selectedIds = new Set();

async function loadItems() {
  try {
    const res  = await fetch("/admin/elibrary/api/all");
    const data = await res.json();
    allItems = data.items || [];
    filtered = [...allItems];
    renderTable();
  } catch(e) {
    document.getElementById("itemsBody").innerHTML =
      '<tr><td colspan="6" class="empty-note">Failed to load. Refresh the page.</td></tr>';
  }
}

function applyFilter() {
  const type  = document.getElementById("filterType").value;
  const title = document.getElementById("filterTitle").value.toLowerCase().trim();
  filtered = allItems.filter(item => {
    return (!type  || item.libraryType === type) &&
           (!title || item.title.toLowerCase().includes(title));
  });
  currentPage = 1;
  renderTable();
}

function resetFilter() {
  document.getElementById("filterType").value  = "";
  document.getElementById("filterTitle").value = "";
  filtered    = [...allItems];
  currentPage = 1;
  renderTable();
}

function renderTable() {
  const start      = (currentPage - 1) * PER_PAGE;
  const pageItems  = filtered.slice(start, start + PER_PAGE);
  const totalPages = Math.ceil(filtered.length / PER_PAGE) || 1;
  const tbody      = document.getElementById("itemsBody");

  document.getElementById("totalCount").textContent = filtered.length + " items";
  document.getElementById("pageInfo").textContent   = "Page " + currentPage + " of " + totalPages;

  const prevBtn = document.getElementById("prevBtn");
  const nextBtn = document.getElementById("nextBtn");
  prevBtn.classList.toggle("disabled", currentPage <= 1);
  nextBtn.classList.toggle("disabled", currentPage >= totalPages);

  if (!pageItems.length) {
    tbody.innerHTML = '<tr><td colspan="6" class="empty-note">No items found.</td></tr>';
    document.getElementById("checkAll").checked = false;
    return;
  }

  tbody.innerHTML = pageItems.map(item => `
    <tr>
      <td><input type="checkbox" value="${item._id}"
        ${selectedIds.has(item._id) ? "checked" : ""}
        onchange="toggleItem('${item._id}', this.checked)"></td>
      <td class="truncate" title="${item.title}" style="font-weight:500;color:#888">${item.title}</td>
      <td><span class="badge ${item.libraryType === 'spiritual' ? 'badge-spiritual' : 'badge-basic'}">${item.libraryType}</span></td>
      <td style="color:#888">${item.author || '—'}</td>
      <td>
        <span class="avail-dot ${item.availability}"></span>
        <span style="color:#555">${item.availability}</span>
      </td>
      <td style="color:#aaa;font-size:.78rem">${new Date(item.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'})}</td>
    </tr>
  `).join("");

  document.getElementById("checkAll").checked =
    pageItems.length > 0 && pageItems.every(i => selectedIds.has(i._id));

  updateSelectBar();
}

function changePage(dir) {
  const totalPages = Math.ceil(filtered.length / PER_PAGE) || 1;
  currentPage = Math.min(Math.max(1, currentPage + dir), totalPages);
  renderTable();
}

function toggleItem(id, checked) {
  checked ? selectedIds.add(id) : selectedIds.delete(id);
  updateSelectBar();
}

function toggleAll(cb) {
  const start = (currentPage - 1) * PER_PAGE;
  filtered.slice(start, start + PER_PAGE).forEach(item => {
    cb.checked ? selectedIds.add(item._id) : selectedIds.delete(item._id);
  });
  renderTable();
}

function clearSelection() {
  selectedIds.clear();
  renderTable();
}

function updateSelectBar() {
  const bar = document.getElementById("selectBar");
  document.getElementById("selectCount").textContent = selectedIds.size + " selected";
  bar.classList.toggle("visible", selectedIds.size > 0);
}

function showConfirm() {
  if (!selectedIds.size) return;
  document.getElementById("confirmText").textContent =
    "This will permanently delete " + selectedIds.size + " item(s). This cannot be undone.";
  document.getElementById("confirmModal").classList.add("show");
}
function hideConfirm() {
  document.getElementById("confirmModal").classList.remove("show");
}

async function executeDelete() {
  const btn = document.getElementById("confirmBtn");
  btn.disabled    = true;
  btn.textContent = "Deleting…";

  try {
    const ids = Array.from(selectedIds);
    const res  = await fetch("/admin/elibrary/mass-delete", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ ids }),
    });
    const data = await res.json();
    hideConfirm();

    if (data.success) {
      allItems = allItems.filter(i => !ids.includes(i._id));
      filtered = filtered.filter(i => !ids.includes(i._id));
      selectedIds.clear();
      const totalPages = Math.ceil(filtered.length / PER_PAGE) || 1;
      if (currentPage > totalPages) currentPage = totalPages;
      renderTable();
      showToast("✅ " + data.deleted + " item(s) deleted", false);
    } else {
      showToast("❌ Delete failed: " + (data.error || "Unknown error"), true);
    }
  } catch(e) {
    hideConfirm();
    showToast("❌ Network error. Try again.", true);
  }

  btn.disabled    = false;
  btn.textContent = "Yes, Delete";
}

function showToast(msg, isError) {
  const t = document.createElement("div");
  t.className   = "toast";
  t.textContent = msg;
  t.style.background = isError ? "#c62828" : "#2e7d32";
  document.body.appendChild(t);
  setTimeout(() => {
    t.style.opacity = "0";
    setTimeout(() => t.remove(), 300);
  }, 3000);
}

loadItems();
</script>
</body>
</html>
