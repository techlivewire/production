<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Edit eLibrary Item – Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/style.css" />
  <link rel="stylesheet" href="/css/eLibraryEdit.css" />

</head>
<body>
<div class="app">
  <aside class="sidebar">
    <h2>Admin Panel</h2>
    <nav>
      <a href="/admin">Dashboard</a>
    
      <a href="/admin/elibrary" class="active">eLibrary</a>
    </nav>
  </aside>

  <main class="main">
    <header class="header"><h1>Edit eLibrary Item</h1></header>

    <section class="card">
      <p class="breadcrumb"><a href="/admin" style="color:white">Admin</a> › <a href="/admin/elibrary" style="color:white">eLibrary</a> › Edit</p>

      <div class="stats-bar">
        <span class="stat-pill">Views: <strong><%= item.views %></strong></span>
        <span class="stat-pill">Downloads: <strong><%= item.downloads %></strong></span>
        <span class="stat-pill">Added: <strong><%= new Date(item.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></strong></span>
      </div>

      <div class="type-label <%= item.libraryType %>">
        <%= item.libraryType === 'spiritual' ? '🕉️ Spiritual' : '📚 Basic / Academic' %>
      </div>

      <% if (error) { %>
        <div class="error-box"><strong>Error:</strong> <%= error %></div>
      <% } %>

      <form method="POST" action="/admin/elibrary/edit/<%= item._id %>" enctype="multipart/form-data">
        <input type="hidden" name="libraryType" value="<%= item.libraryType %>">

        <div class="form-grid">

          <!-- Core -->
          <div class="form-group full">
            <label>Title *</label>
            <input type="text" name="title" value="<%= item.title %>" required>
          </div>
          <div class="form-group">
            <label>Author / Commentator</label>
            <input type="text" name="author" value="<%= item.author || '' %>">
          </div>
          <div class="form-group">
            <label>Language</label>
            <input type="text" name="language" value="<%= item.language || 'English' %>">
          </div>
          <div class="form-group">
            <label>Publication Year</label>
            <input type="number" name="publicationYear" value="<%= item.publicationYear || '' %>" min="1" max="<%= new Date().getFullYear()+1 %>">
          </div>
          <div class="form-group">
            <label>Reading Level</label>
            <select name="readingLevel">
              <option value="">— Select —</option>
              <option value="beginner"     <%= item.readingLevel==='beginner'     ?'selected':'' %>>Beginner</option>
              <option value="intermediate" <%= item.readingLevel==='intermediate' ?'selected':'' %>>Intermediate</option>
              <option value="advanced"     <%= item.readingLevel==='advanced'     ?'selected':'' %>>Advanced</option>
            </select>
          </div>
          <div class="form-group full">
            <label>Description</label>
            <textarea name="description"><%= item.description || '' %></textarea>
          </div>
          <div class="form-group full">
            <label>Tags <span class="hint">(comma separated)</span></label>
            <input type="text" name="tags" value="<%= (item.tags||[]).join(', ') %>">
          </div>

          <!-- Spiritual -->
          <% if (item.libraryType === 'spiritual') { %>
          <% const s = item.spiritual || {}; %>
          <div class="section-divider"><h3>🕉️ Scripture & Text</h3></div>
          <div class="form-group"><label>Scripture Name</label><input type="text" name="scriptureName" value="<%= s.scriptureName||'' %>"></div>
          <div class="form-group"><label>Section / Chapter</label><input type="text" name="section" value="<%= s.section||'' %>"></div>
          <div class="form-group"><label>Shloka / Verse</label><input type="text" name="shloka" value="<%= s.shloka||'' %>"></div>
          <div class="form-group"><label>Commentary By</label><input type="text" name="commentaryBy" value="<%= s.commentaryBy||'' %>"></div>

          <div class="section-divider"><h3>🧘 Philosophy & Practice</h3></div>
          <div class="form-group">
            <label>Darshana</label>
            <select name="darshana">
              <option value="">— Select —</option>
              <% ['Vedanta','Samkhya','Yoga','Nyaya','Vaisheshika','Mimamsa'].forEach(d => { %>
                <option value="<%= d %>" <%= s.darshana===d?'selected':'' %>><%= d %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Sampradaya</label>
            <select name="sampradaya">
              <option value="">— Select —</option>
              <% ['Vaishnav','Shaiva','Shakta','Smarta'].forEach(sp => { %>
                <option value="<%= sp %>" <%= s.sampradaya===sp?'selected':'' %>><%= sp %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Practice Type</label>
            <select name="practiceType">
              <option value="">— Select —</option>
              <% ['Meditation','Yoga','Bhakti','Karma','Mantra','Ritual'].forEach(p => { %>
                <option value="<%= p %>" <%= s.practiceType===p?'selected':'' %>><%= p %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group"><label>Deity</label><input type="text" name="deity" value="<%= s.deity||'' %>"></div>
          <div class="form-group">
            <label>Spiritual Concept</label>
            <select name="spiritualConcept">
              <option value="">— Select —</option>
              <% ['Dharma','Karma','Moksha','Atman','Brahman','Maya'].forEach(c => { %>
                <option value="<%= c %>" <%= s.spiritualConcept===c?'selected':'' %>><%= c %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Lifestyle</label>
            <select name="lifestyle">
              <option value="">— Select —</option>
              <% ['Ayurveda','Dinacharya','Ethics'].forEach(l => { %>
                <option value="<%= l %>" <%= s.lifestyle===l?'selected':'' %>><%= l %></option>
              <% }) %>
            </select>
          </div>

          <div class="section-divider"><h3>🕰️ Era & Interpretation</h3></div>
          <div class="form-group">
            <label>Yuga</label>
            <select name="yuga">
              <option value="">— Select —</option>
              <% ['Satya','Treta','Dvapara','Kali'].forEach(y => { %>
                <option value="<%= y %>" <%= s.yuga===y?'selected':'' %>><%= y %> Yuga</option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Historical Period</label>
            <select name="historicalPeriod">
              <option value="">— Select —</option>
              <% ['Vedic','Epic','Puranic','Medieval','Modern'].forEach(h => { %>
                <option value="<%= h %>" <%= s.historicalPeriod===h?'selected':'' %>><%= h %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Translation Type</label>
            <select name="translationType">
              <option value="">— Select —</option>
              <% ['Original Sanskrit','Translation','Commentary','Simplified','Scholarly'].forEach(t => { %>
                <option value="<%= t %>" <%= s.translationType===t?'selected':'' %>><%= t %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group">
            <label>Audience</label>
            <select name="audience">
              <option value="">— Select —</option>
              <% ['Beginner/Seeker','Practitioner','Advanced','Children/Youth','Scholars'].forEach(a => { %>
                <option value="<%= a %>" <%= s.audience===a?'selected':'' %>><%= a %></option>
              <% }) %>
            </select>
          </div>
          <% } %>

          <!-- Basic -->
          <% if (item.libraryType === 'basic') { %>
          <% const b = item.basic || {}; %>
          <div class="section-divider"><h3>📚 Academic Details</h3></div>
          <div class="form-group"><label>Category</label><input type="text" name="category" value="<%= b.category||'' %>"></div>
          <div class="form-group">
            <label>Document Type</label>
            <select name="documentType">
              <option value="">— Select —</option>
              <% ['book','journal','thesis','report','article'].forEach(d => { %>
                <option value="<%= d %>" <%= b.documentType===d?'selected':'' %>><%= d.charAt(0).toUpperCase()+d.slice(1) %></option>
              <% }) %>
            </select>
          </div>
          <div class="form-group"><label>Publisher</label><input type="text" name="publisher" value="<%= b.publisher||'' %>"></div>
          <div class="form-group"><label>Institution</label><input type="text" name="institution" value="<%= b.institution||'' %>"></div>
          <div class="form-group"><label>Course</label><input type="text" name="course" value="<%= b.course||'' %>"></div>
          <div class="form-group">
            <label>Keywords <span class="hint">(comma separated)</span></label>
            <input type="text" name="keywords" value="<%= (b.keywords||[]).join(', ') %>">
          </div>
          <div class="form-group full">
            <label class="checkbox-row">
              <input type="checkbox" name="isPeerReviewed" <%= b.isPeerReviewed?'checked':'' %>>
              <span style="text-transform:none;letter-spacing:0;font-size:.88rem;color:#333;">Peer-reviewed</span>
            </label>
          </div>
          <% } %>

          <!-- File & Access -->
          <div class="section-divider full"><h3>📁 File & Access</h3></div>
          <div class="form-group">
            <label>File Format</label>
            <select name="fileFormat">
              <option value="">— Select —</option>
              <option value="PDF"  <%= item.fileFormat==='PDF'  ?'selected':'' %>>PDF</option>
              <option value="EPUB" <%= item.fileFormat==='EPUB' ?'selected':'' %>>EPUB</option>
              <option value="DOC"  <%= item.fileFormat==='DOC'  ?'selected':'' %>>DOC</option>
            </select>
          </div>
          <div class="form-group">
            <label>Availability</label>
            <select name="availability">
              <option value="full"       <%= item.availability==='full'       ?'selected':'' %>>Full Access</option>
              <option value="preview"    <%= item.availability==='preview'    ?'selected':'' %>>Preview Only</option>
              <option value="restricted" <%= item.availability==='restricted' ?'selected':'' %>>Restricted</option>
            </select>
          </div>
          <div class="form-group full">
            <label>Replace File <span class="hint">(leave blank to keep existing)</span></label>
            <input type="file" name="file" accept=".pdf,.epub,.doc,.docx">
            <% if (item.fileUrl) { %>
              <div class="current-file">Current: <a href="<%= item.fileUrl %>" target="_blank"><%= item.fileUrl %></a></div>
            <% } %>
            <input type="hidden" name="existingFileUrl" value="<%= item.fileUrl||'' %>">
          </div>
          <div class="form-group full" style="flex-direction:row;gap:1.5rem;flex-wrap:wrap">
            <label class="checkbox-row">
              <input type="checkbox" name="isDownloadable" <%= item.isDownloadable?'checked':'' %>>
              <span style="text-transform:none;letter-spacing:0;font-size:.88rem;color:#333;">Allow download</span>
            </label>
            <label class="checkbox-row">
              <input type="checkbox" name="isFeatured" <%= item.isFeatured?'checked':'' %>>
              <span style="text-transform:none;letter-spacing:0;font-size:.88rem;color:#333;">⭐ Mark as featured</span>
            </label>
          </div>

        </div>

        <div style="margin-top:1.5rem;display:flex;align-items:center">
          <button type="submit" class="btn-save">Save Changes</button>
          <a href="/admin/elibrary" class="btn-cancel">Cancel</a>
        </div>
      </form>
    </section>
  </main>
</div>
</body>
</html>
