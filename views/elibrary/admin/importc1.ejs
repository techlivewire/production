<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Bulk Import & Mass Delete – eLibrary Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    /* ── Layout ── */
    .breadcrumb { font-size:.8rem; color:#888; margin-bottom:.75rem; }
    .breadcrumb a { color:#f8f8f8; text-decoration:none; }
    .breadcrumb a:hover { text-decoration:underline; }

    .section-title {
      font-size:1.05rem; font-weight:700; color:#ffffff;
      margin-bottom:1.25rem; padding-bottom:.6rem;
      border-bottom:2px solid #f0ebe0;
      display:flex; align-items:center; gap:.5rem;
    }

    /* ── Upload boxes ── */
    .upload-grid { display:grid; grid-template-columns:1fr 1fr; gap:1.5rem; margin-bottom:1.5rem; }
    @media(max-width:650px){ .upload-grid { grid-template-columns:1fr; } }

    .upload-box {
      border:2px dashed #ccc;
      border-radius:12px;
      padding:2rem 1rem;
      text-align:center;
      cursor:pointer;
      transition:all .2s;
      position:relative;
      background:#fafafa;
    }
    .upload-box:hover { border-color:#1c1430; background:#f5f0e8; }
    .upload-box.filled { border-color:#2e7d32; border-style:solid; background:#f1f8e9; }
    .upload-box input[type="file"] {
      position:absolute; inset:0; width:100%; height:100%;
      opacity:0; cursor:pointer;
    }
    .upload-box .icon  { font-size:2.2rem; margin-bottom:.6rem; }
    .upload-box .label { font-size:.88rem; font-weight:600; color:#333; margin-bottom:.25rem; }
    .upload-box .hint  { font-size:.75rem; color:#aaa; }
    .upload-box .fname { font-size:.8rem; color:#2e7d32; font-weight:600; margin-top:.6rem; display:none; }

    /* ── Buttons ── */
    .btn-primary {
      padding:.65rem 1.75rem; background:#1c1430; color:#fff;
      border:none; border-radius:8px; font-size:.9rem; font-weight:600;
      cursor:pointer; transition:background .2s; font-family:inherit;
      display:inline-flex; align-items:center; gap:.5rem;
    }
    .btn-primary:hover { background:#e8701a; }
    .btn-primary:disabled { opacity:.5; cursor:not-allowed; }

    .btn-danger {
      padding:.55rem 1.2rem; background:#c62828; color:#fff;
      border:none; border-radius:8px; font-size:.85rem; font-weight:600;
      cursor:pointer; transition:background .2s; font-family:inherit;
    }
    .btn-danger:hover { background:#b71c1c; }
    .btn-danger:disabled { opacity:.4; cursor:not-allowed; }

    .btn-outline {
      padding:.55rem 1.1rem; background:transparent; color:#555;
      border:1px solid #ddd; border-radius:8px; font-size:.85rem;
      cursor:pointer; font-family:inherit; transition:background .2s;
    }
    /* .btn-outline:hover { background:#f5f0e8; } */

    /* ── Spinner ── */
    .spinner {
      width:16px; height:16px;
      border:2px solid rgba(255,255,255,.4);
      border-top-color:#fff;
      border-radius:50%;
      animation:spin .7s linear infinite;
      display:none;
    }
    @keyframes spin { to { transform:rotate(360deg); } }

    /* ── Result box ── */
    .result-wrap { margin-top:1.5rem; }
    .result-header {
      padding:.9rem 1.25rem;
      display:flex; align-items:center; gap:.65rem;
      border-radius:10px 10px 0 0;
      border:1px solid #ddd; border-bottom:none;
    }
    .result-header.ok   { background:#e8f5e9; border-color:#c8e6c9; }
    .result-header.fail { background:#ffebee; border-color:#ffcdd2; }
    .result-header h3   { font-size:.95rem; font-weight:700; }

    .stat-row {
      display:flex; gap:.6rem; flex-wrap:wrap;
      padding:.9rem 1.25rem; background:#fafafa;
      border:1px solid #ddd; border-top:none; border-bottom:none;
    }
    .stat-chip { padding:.28rem .75rem; border-radius:20px; font-size:.78rem; font-weight:600; }
    .chip-blue   { background:#e3f2fd; color:#1565c0; }
    .chip-green  { background:#e8f5e9; color:#2e7d32; }
    .chip-orange { background:#fff3e0; color:#e65100; }
    .chip-red    { background:#ffebee; color:#c62828; }

    .log-wrap { border:1px solid #ddd; border-top:none; border-radius:0 0 10px 10px; overflow:auto; max-height:340px; }
    .log-table { width:100%; border-collapse:collapse; font-size:.8rem; }
    .log-table th { background:#f5f5f5; padding:.5rem .85rem; text-align:left; font-size:.7rem; letter-spacing:.07em; text-transform:uppercase; color:#999; position:sticky; top:0; }
    .log-table td { padding:.48rem .85rem; border-bottom:1px solid #f0f0f0; }
    .t-ok    { color:#2e7d32; font-weight:600; }
    .t-skip  { color:#e65100; }
    .t-warn  { color:#d4a017; }
    .t-error { color:#c62828; font-weight:600; }

    /* ── Mass delete ── */
    .mass-delete-wrap { margin-top:.5rem; }

    .filter-bar {
      display:flex; gap:.6rem; flex-wrap:wrap;
      margin-bottom:1rem; align-items:flex-end;
    }
    .filter-bar label { font-size:.72rem; letter-spacing:.06em; text-transform:uppercase; color:#888; display:block; margin-bottom:.3rem; }
    .filter-bar select, .filter-bar input {
      padding:.48rem .75rem; border:1px solid #ddd; border-radius:7px;
      font-family:inherit; font-size:.83rem; color:#1c1430; background:#fafafa;
    }
    .filter-bar select:focus, .filter-bar input:focus { outline:none; border-color:#1c1430; }

    .items-table { width:100%; border-collapse:collapse; font-size:.83rem; }
    .items-table th {
      background:#f5f0e8; padding:.6rem .9rem; text-align:left;
      font-size:.7rem; letter-spacing:.08em; text-transform:uppercase;
      color:#888; border-bottom:2px solid #e8dcc8; position:sticky; top:0;
    }
    .items-table td { padding:.6rem .9rem; border-bottom:1px solid #eee; vertical-align:middle; }
    .items-table tr:hover td { background:#fafafa; }
    .items-table input[type="checkbox"] { width:15px; height:15px; accent-color:#c62828; cursor:pointer; }

    .badge { font-size:.65rem; padding:.18rem .48rem; border-radius:4px; font-weight:700; text-transform:uppercase; letter-spacing:.06em; }
    .b-sp { background:#fef3e2; color:#e67e22; }
    .b-ba { background:#e8f5e9; color:#2e7d32; }

    .select-bar {
      display:flex; align-items:center; gap:.75rem;
      padding:.7rem 1rem; background:#fff3e0;
      border:1px solid #ffe0b2; border-radius:8px;
      margin-bottom:1rem; flex-wrap:wrap;
      display:none;
    }
    .select-bar.visible { display:flex; }
    .select-count { font-size:.85rem; font-weight:600; color:#e65100; }

    .table-wrap { border:1px solid #ddd; border-radius:10px; overflow:auto; max-height:420px; }

    .delete-confirm {
      display:none; position:fixed; inset:0;
      background:rgba(0,0,0,.5); z-index:1000;
      align-items:center; justify-content:center;
    }
    .delete-confirm.show { display:flex; }
    .confirm-box {
      background:#fff; border-radius:14px; padding:2rem;
      max-width:400px; width:90%; text-align:center;
      box-shadow:0 20px 60px rgba(0,0,0,.2);
    }
    .confirm-box .icon { font-size:3rem; margin-bottom:.75rem; }
    .confirm-box h3 { font-size:1.1rem; font-weight:700; margin-bottom:.5rem; color:#c62828; }
    .confirm-box p  { font-size:.85rem; color:#666; margin-bottom:1.25rem; }
    .confirm-btns   { display:flex; gap:.75rem; justify-content:center; }

    .empty-state { text-align:center; padding:3rem; color:#aaa; font-size:.88rem; }
  </style>
</head>
<body>
<div class="app">
  <aside class="sidebar">
    <h2>Admin Panel</h2>
    <nav>
      <a href="/admin">Dashboard</a>
      <a href="/admin/library">Library</a>
      <a href="/admin/elibrary" class="active">eLibrary</a>
    </nav>
  </aside>

  <main class="main">
    <header class="header"><h1>Bulk Import & Mass Delete</h1></header>

    <!-- ── SECTION 1: IMPORT ─────────────────────────────────────────────── -->
    <section class="card">
      <p class="breadcrumb"><a href="/admin">Admin</a> › <a href="/admin/elibrary">eLibrary</a> › Bulk Import</p>
      <div class="section-title">📥 Bulk Import from Excel + ZIP</div>

      <form method="POST" action="/admin/elibrary/import" enctype="multipart/form-data" id="importForm">

        <div class="upload-grid">

          <!-- Excel -->
          <div class="upload-box" id="excelBox">
            <input type="file" name="excel" accept=".xlsx,.xls" id="excelInput" required>
            <div class="icon">📊</div>
            <div class="label">Upload Excel File</div>
            <div class="hint">.xlsx — one item per row</div>
            <div class="fname" id="excelName"></div>
          </div>

          <!-- ZIP -->
          <div class="upload-box" id="zipBox">
            <input type="file" name="zip" accept=".zip" id="zipInput" required>
            <div class="icon">🗜️</div>
            <div class="label">Upload ZIP of PDFs</div>
            <div class="hint">.zip — all PDFs flat inside, no subfolders</div>
            <div class="fname" id="zipName"></div>
          </div>

        </div>

        <div style="display:flex;align-items:center;gap:1rem;flex-wrap:wrap">
          <button type="submit" class="btn-primary" id="importBtn">
            <span id="importBtnText">Import Now</span>
            <span class="spinner" id="importSpinner"></span>
          </button>
          <a href="/elibrary-template.xlsx" download class="btn-outline">⬇ Download Template</a>
          <!-- <span style="font-size:.75rem;color:#aaa">Required columns: <strong>title</strong>, <strong>libraryType</strong></span> -->
        </div>

      </form>

      <!-- Result -->
      <% if (result) { %>
        <div class="result-wrap">
          <% if (!result.success) { %>
            <div class="result-header fail">
              <span>❌</span><h3>Import Failed — <%= result.error %></h3>
            </div>
          <% } else { %>
            <div class="result-header ok">
              <span>✅</span><h3>Import Complete</h3>
            </div>
            <div class="stat-row">
              <span class="stat-chip chip-blue">📦 <%= result.extracted %> files from ZIP</span>
              <span class="stat-chip chip-blue">📊 <%= result.total %> rows in Excel</span>
              <span class="stat-chip chip-green">✅ <%= result.inserted %> imported</span>
              <span class="stat-chip chip-orange">⏭️ <%= result.skipped %> skipped</span>
              <span class="stat-chip chip-red">❌ <%= result.errors %> errors</span>
            </div>
            <div class="log-wrap">
              <table class="log-table">
                <thead><tr><th>Row</th><th>Status</th><th>Title</th><th>Message</th></tr></thead>
                <tbody>
                  <% result.log.forEach(e => { %>
                    <tr>
                      <td><%= e.row %></td>
                      <td>
                        <% if(e.type==='ok')    { %><span class="t-ok">✅ OK</span><% } %>
                        <% if(e.type==='skip')  { %><span class="t-skip">⏭️ Skipped</span><% } %>
                        <% if(e.type==='warn')  { %><span class="t-warn">⚠️ Warning</span><% } %>
                        <% if(e.type==='error') { %><span class="t-error">❌ Error</span><% } %>
                      </td>
                      <td><%= e.title %></td>
                      <td class="t-<%= e.type %>"><%= e.msg %></td>
                    </tr>
                  <% }) %>
                </tbody>
              </table>
            </div>
            <div style="margin-top:1rem;display:flex;gap:.6rem">
              <a href="/admin/elibrary" class="btn-primary" style="font-size:.85rem;padding:.5rem 1.1rem">View All Items →</a>
              <a href="/elibrary" target="_blank" class="btn-outline">View Public Page ↗</a>
            </div>
          <% } %>
        </div>
      <% } %>
    </section>

    <!-- ── SECTION 2: MASS DELETE ─────────────────────────────────────────── -->
    <section class="card" style="margin-top:1.5rem">
      <div class="section-title">🗑️ Mass Delete Items</div>

      <!-- Filter bar -->
      <div class="filter-bar">
        <div>
          <label>Type</label>
          <select id="filterType">
            <option value="">All Types</option>
            <option value="spiritual">Spiritual</option>
            <option value="basic">Basic</option>
          </select>
        </div>
        <div>
          <label>Search Title</label>
          <input type="text" id="filterTitle" placeholder="Search…" style="width:200px">
        </div>
        <button type="button" class="btn-outline" onclick="filterItems()">Filter</button>
        <button type="button" class="btn-outline" onclick="resetFilter()">Reset</button>
      </div>

      <!-- Selection bar (shows when items selected) -->
      <div class="select-bar" id="selectBar">
        <span class="select-count" id="selectCount">0 selected</span>
        <button type="button" class="btn-danger" onclick="showConfirm()">🗑️ Delete Selected</button>
        <button type="button" class="btn-outline" onclick="clearSelection()">Clear</button>
      </div>

      <!-- Items table -->
      <div class="table-wrap">
        <table class="items-table" id="itemsTable">
          <thead>
            <tr>
              <th><input type="checkbox" id="checkAll" onclick="toggleAll(this)" title="Select all"></th>
              <th>Title</th>
              <th>Type</th>
              <th>Author</th>
              <th>Availability</th>
              <th>Added</th>
            </tr>
          </thead>
          <tbody id="itemsBody">
            <tr><td colspan="6" class="empty-state">Loading items…</td></tr>
          </tbody>
        </table>
      </div>

      <div style="margin-top:.75rem;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:.5rem">
        <span id="totalCount" style="font-size:.8rem;color:#888"></span>
        <div style="display:flex;gap:.5rem">
          <button class="btn-outline" id="prevBtn" onclick="changePage(-1)" disabled>‹ Prev</button>
          <span id="pageInfo" style="font-size:.82rem;color:#888;align-self:center"></span>
          <button class="btn-outline" id="nextBtn" onclick="changePage(1)">Next ›</button>
        </div>
      </div>
    </section>

    <!-- Delete confirmation modal -->
    <div class="delete-confirm" id="confirmModal">
      <div class="confirm-box">
        <div class="icon">⚠️</div>
        <h3>Delete Selected Items?</h3>
        <p id="confirmText">This will permanently delete the selected items. This cannot be undone.</p>
        <div class="confirm-btns">
          <button class="btn-danger" id="confirmDeleteBtn" onclick="executeDelete()">Yes, Delete</button>
          <button class="btn-outline" onclick="hideConfirm()">Cancel</button>
        </div>
      </div>
    </div>

  </main>
</div>

<script>
// ── Import form ───────────────────────────────────────────────────────────────
function setupPicker(inputId, boxId, nameId) {
  const input = document.getElementById(inputId);
  const box   = document.getElementById(boxId);
  const name  = document.getElementById(nameId);
  input.addEventListener("change", () => {
    if (input.files[0]) {
      name.textContent = "✅ " + input.files[0].name;
      name.style.display = "block";
      box.classList.add("filled");
    }
  });
}
setupPicker("excelInput", "excelBox", "excelName");
setupPicker("zipInput",   "zipBox",   "zipName");

document.getElementById("importForm").addEventListener("submit", () => {
  const btn     = document.getElementById("importBtn");
  const txt     = document.getElementById("importBtnText");
  const spinner = document.getElementById("importSpinner");
  btn.disabled      = true;
  txt.textContent   = "Importing…";
  spinner.style.display = "inline-block";
});

// ── Mass delete state ─────────────────────────────────────────────────────────
let allItems    = [];
let filtered    = [];
let currentPage = 1;
const PAGE_SIZE = 20;
let selectedIds = new Set();

// Load all items from server on page load
async function loadAllItems() {
  try {
    const res  = await fetch("/admin/elibrary/api/all");
    const data = await res.json();
    allItems = data.items || [];
    filtered = [...allItems];
    renderTable();
  } catch(e) {
    document.getElementById("itemsBody").innerHTML =
      '<tr><td colspan="6" class="empty-state">Failed to load items. Refresh the page.</td></tr>';
  }
}

function filterItems() {
  const type  = document.getElementById("filterType").value;
  const title = document.getElementById("filterTitle").value.toLowerCase();

  filtered = allItems.filter(item => {
    const matchType  = !type  || item.libraryType === type;
    const matchTitle = !title || item.title.toLowerCase().includes(title);
    return matchType && matchTitle;
  });

  currentPage = 1;
  renderTable();
}

function resetFilter() {
  document.getElementById("filterType").value  = "";
  document.getElementById("filterTitle").value = "";
  filtered    = [...allItems];
  currentPage = 1;
  renderTable();
}

function renderTable() {
  const start = (currentPage - 1) * PAGE_SIZE;
  const end   = start + PAGE_SIZE;
  const page  = filtered.slice(start, end);

  const tbody = document.getElementById("itemsBody");
  const total = document.getElementById("totalCount");
  const pageInfo = document.getElementById("pageInfo");
  const prevBtn  = document.getElementById("prevBtn");
  const nextBtn  = document.getElementById("nextBtn");
  const totalPages = Math.ceil(filtered.length / PAGE_SIZE);

  total.textContent    = filtered.length + " items";
  pageInfo.textContent = `Page ${currentPage} of ${totalPages || 1}`;
  prevBtn.disabled     = currentPage <= 1;
  nextBtn.disabled     = currentPage >= totalPages;

  if (page.length === 0) {
    tbody.innerHTML = '<tr><td colspan="6" class="empty-state">No items found.</td></tr>';
    return;
  }

  tbody.innerHTML = page.map(item => `
    <tr>
      <td><input type="checkbox" value="${item._id}"
        ${selectedIds.has(item._id) ? "checked" : ""}
        onchange="toggleItem('${item._id}', this.checked)">
      </td>
      <td style="font-weight:500;max-width:220px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap" title="${item.title}">${item.title}</td>
      <td><span class="badge ${item.libraryType === 'spiritual' ? 'b-sp' : 'b-ba'}">${item.libraryType}</span></td>
      <td style="color:#888">${item.author || '—'}</td>
      <td style="color:#888">${item.availability}</td>
      <td style="color:#aaa;font-size:.78rem">${new Date(item.createdAt).toLocaleDateString('en-IN', {day:'2-digit',month:'short',year:'numeric'})}</td>
    </tr>
  `).join("");

  updateSelectBar();

  // Sync checkAll state
  const allChecked = page.every(item => selectedIds.has(item._id));
  document.getElementById("checkAll").checked = allChecked && page.length > 0;
}

function changePage(dir) {
  currentPage += dir;
  renderTable();
}

function toggleItem(id, checked) {
  if (checked) selectedIds.add(id);
  else         selectedIds.delete(id);
  updateSelectBar();
}

function toggleAll(checkbox) {
  const start = (currentPage - 1) * PAGE_SIZE;
  const page  = filtered.slice(start, start + PAGE_SIZE);
  page.forEach(item => {
    if (checkbox.checked) selectedIds.add(item._id);
    else                  selectedIds.delete(item._id);
  });
  renderTable();
}

function clearSelection() {
  selectedIds.clear();
  renderTable();
}

function updateSelectBar() {
  const bar   = document.getElementById("selectBar");
  const count = document.getElementById("selectCount");
  count.textContent = selectedIds.size + " selected";
  bar.classList.toggle("visible", selectedIds.size > 0);
}

// Confirm modal
function showConfirm() {
  if (selectedIds.size === 0) return;
  document.getElementById("confirmText").textContent =
    `This will permanently delete ${selectedIds.size} item(s). This cannot be undone.`;
  document.getElementById("confirmModal").classList.add("show");
}
function hideConfirm() {
  document.getElementById("confirmModal").classList.remove("show");
}

async function executeDelete() {
  const btn = document.getElementById("confirmDeleteBtn");
  btn.disabled    = true;
  btn.textContent = "Deleting…";

  try {
    const ids = Array.from(selectedIds);
    const res = await fetch("/admin/elibrary/mass-delete", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify({ ids }),
    });
    const data = await res.json();

    hideConfirm();

    if (data.success) {
      // Remove deleted items from local arrays
      allItems = allItems.filter(item => !ids.includes(item._id));
      filtered = filtered.filter(item => !ids.includes(item._id));
      selectedIds.clear();

      // Show toast
      showToast(`✅ ${data.deleted} item(s) deleted successfully`);

      // Adjust page if needed
      const totalPages = Math.ceil(filtered.length / PAGE_SIZE);
      if (currentPage > totalPages) currentPage = Math.max(1, totalPages);

      renderTable();
    } else {
      showToast("❌ Delete failed: " + (data.error || "Unknown error"), true);
    }
  } catch(e) {
    showToast("❌ Network error. Try again.", true);
    hideConfirm();
  }

  btn.disabled    = false;
  btn.textContent = "Yes, Delete";
}

// Simple toast
function showToast(msg, isError = false) {
  const toast = document.createElement("div");
  toast.textContent = msg;
  Object.assign(toast.style, {
    position:"fixed", bottom:"2rem", right:"2rem",
    background: isError ? "#c62828" : "#2e7d32",
    color:"#fff", padding:".75rem 1.25rem",
    borderRadius:"8px", fontSize:".88rem",
    fontWeight:"600", zIndex:"9999",
    boxShadow:"0 4px 20px rgba(0,0,0,.2)",
    transition:"opacity .3s"
  });
  document.body.appendChild(toast);
  setTimeout(() => { toast.style.opacity = "0"; setTimeout(() => toast.remove(), 300); }, 3000);
}

// Init
loadAllItems();
</script>
</body>
</html>
