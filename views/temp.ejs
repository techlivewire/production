<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>eLibrary Admin – SBU</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .lib-header { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; margin-bottom:1.5rem; }
    .btn-add { padding:.55rem 1.2rem; background:#1c1430; color:#fff; border:none; border-radius:7px; font-size:.88rem; font-weight:600; cursor:pointer; text-decoration:none; transition:background .2s; }
    .btn-add:hover { background:#e8701a; }
    .type-tabs { display:flex; gap:.4rem; margin-bottom:1.5rem; flex-wrap:wrap; }
    .type-tab { padding:.4rem .9rem; border:1px solid #ddd; border-radius:20px; font-size:.82rem; text-decoration:none; color:#555; transition:all .15s; background:#fff; }
    .type-tab.active, .type-tab:hover { background:#1c1430; color:#fff; border-color:#1c1430; }
    .eli-table { width:100%; border-collapse:collapse; font-size:.86rem; }
    .eli-table th { background:#f5f0e8; padding:.65rem 1rem; text-align:left; font-size:.72rem; letter-spacing:.08em; text-transform:uppercase; color:#666; border-bottom:2px solid #e8dcc8; }
    .eli-table td { padding:.7rem 1rem; border-bottom:1px solid #eee; vertical-align:middle; }
    .eli-table tr:hover td { background:#fafafa; }
    .badge { font-size:.65rem; padding:.18rem .5rem; border-radius:4px; font-weight:700; letter-spacing:.06em; text-transform:uppercase; }
    .badge-spiritual { background:#fef3e2; color:#e67e22; }
    .badge-basic     { background:#e8f5e9; color:#2e7d32; }
    .badge-type      { background:#f5f0e8; color:#7a6e5f; }
    .avail-dot { display:inline-block; width:7px; height:7px; border-radius:50%; margin-right:.35rem; }
    .avail-dot.full { background:#2e7d32; } .avail-dot.preview { background:#d4a017; } .avail-dot.restricted { background:#c0392b; }
    .action-btns { display:flex; gap:.4rem; }
    .btn-edit   { padding:.28rem .65rem; background:#e3f2fd; color:#1565c0; border:none; border-radius:5px; font-size:.76rem; text-decoration:none; cursor:pointer; }
    .btn-delete { padding:.28rem .65rem; background:#ffebee; color:#c62828; border:none; border-radius:5px; font-size:.76rem; cursor:pointer; }
    .btn-edit:hover { background:#bbdefb; } .btn-delete:hover { background:#ffcdd2; }
    .empty-row td { text-align:center; color:#aaa; padding:2rem; font-style:italic; }
    .pagination { display:flex; gap:.4rem; margin-top:1.25rem; }
    .pag-btn { padding:.35rem .75rem; border:1px solid #ddd; border-radius:6px; background:#fff; color:#333; font-size:.83rem; text-decoration:none; }
    .pag-btn.active { background:#1c1430; border-color:#1c1430; color:#fff; }
    .pag-btn.disabled { opacity:.35; pointer-events:none; }
    .truncate { max-width:200px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
    .star { color:#d4a017; font-size:.8rem; }
  </style>
</head>
<body>
<div class="app">
  <aside class="sidebar">
    <h2>Admin Panel</h2>
    <nav>
      <a href="/admin">Dashboard</a>
      <a href="/admin/library">Library</a>
      <a href="/admin/elibrary" class="active">eLibrary</a>
    </nav>
  </aside>

  <main class="main">
    <header class="header"><h1>eLibrary Manager</h1></header>

    <section class="card">
      <div class="lib-header">
        <div>
          <h2>All Items</h2>
          <p style="font-size:.82rem;color:#888;margin-top:.2rem"><%= total %> total items</p>
        </div>
        <a href="/admin/elibrary/add" class="btn-add">+ Add New Item</a>
      </div>

      <div class="type-tabs">
        <a href="/admin/elibrary"                   class="type-tab <%= typeFilter === ''          ? 'active' : '' %>">All</a>
        <a href="/admin/elibrary?type=spiritual"     class="type-tab <%= typeFilter === 'spiritual' ? 'active' : '' %>">🕉️ Spiritual</a>
        <a href="/admin/elibrary?type=basic"         class="type-tab <%= typeFilter === 'basic'     ? 'active' : '' %>">📚 Basic/Academic</a>
      </div>

      <div style="overflow-x:auto">
        <table class="eli-table">
          <thead>
            <tr>
              <th>Title</th>
              <th>Type</th>
              <th>Author</th>
              <th>Format</th>
              <th>Availability</th>
              <th>Views</th>
              <th>Featured</th>
              <th>Added</th>
              <th>Actions</th>
            </tr>
          </thead>
          <tbody>
            <% if (items.length === 0) { %>
              <tr class="empty-row"><td colspan="9">No items yet. <a href="/admin/elibrary/add">Add one →</a></td></tr>
            <% } %>
            <% items.forEach(item => { %>
            <tr>
              <td>
                <div class="truncate" title="<%= item.title %>">
                  <a href="/elibrary/<%= item._id %>" target="_blank" style="color:#1c1430;text-decoration:none;font-weight:500"><%= item.title %></a>
                </div>
              </td>
              <td>
                <span class="badge badge-<%= item.libraryType %>"><%= item.libraryType %></span>
              </td>
              <td><%= item.author || '—' %></td>
              <td><%= item.fileFormat || '—' %></td>
              <td><span class="avail-dot <%= item.availability %>"></span><%= item.availability %></td>
              <td><%= item.views %></td>
              <td><% if (item.isFeatured) { %><span class="star">⭐</span><% } else { %>—<% } %></td>
              <td><%= new Date(item.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %></td>
              <td>
                <div class="action-btns">
                  <a href="/admin/elibrary/edit/<%= item._id %>" class="btn-edit">Edit</a>
                  <form method="POST" action="/admin/elibrary/delete/<%= item._id %>" onsubmit="return confirm('Delete this item?')">
                    <button type="submit" class="btn-delete">Delete</button>
                  </form>
                </div>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
        <div class="pagination">
          <a href="?page=<%= page-1 %><%= typeFilter ? '&type='+typeFilter : '' %>" class="pag-btn <%= page<=1?'disabled':'' %>">‹</a>
          <% for(let p=1;p<=totalPages;p++){ %>
            <a href="?page=<%= p %><%= typeFilter ? '&type='+typeFilter : '' %>" class="pag-btn <%= p===page?'active':'' %>"><%= p %></a>
          <% } %>
          <a href="?page=<%= page+1 %><%= typeFilter ? '&type='+typeFilter : '' %>" class="pag-btn <%= page>=totalPages?'disabled':'' %>">›</a>
        </div>
      <% } %>
    </section>
  </main>
</div>
</body>
</html>
