<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Edit Library Item – SBU Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    @media(max-width:680px){ .form-grid { grid-template-columns: 1fr; } }
    .form-group { display: flex; flex-direction: column; gap: .35rem; }
    .form-group.full { grid-column: 1/-1; }
    .form-group label { font-size: .78rem; letter-spacing: .07em; text-transform: uppercase; color: #888; font-weight: 500; }
    .form-group input,
    .form-group select,
    .form-group textarea {
      padding: .6rem .85rem;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: .9rem;
      font-family: inherit;
      color: #1a1a2e;
      transition: border-color .2s;
    }
    .form-group input:focus,
    .form-group select:focus,
    .form-group textarea:focus {
      outline: none;
      border-color: #2d5a27;
    }
    .form-group textarea { resize: vertical; min-height: 100px; }
    .required-star { color: #c0392b; }
    .checkbox-row { display: flex; align-items: center; gap: .5rem; font-size: .9rem; margin-top: .5rem; }
    .checkbox-row input[type="checkbox"] { width: 16px; height: 16px; }
    .error-box { background: #ffebee; border: 1px solid #ffcdd2; border-radius: 8px; padding: .75rem 1rem; font-size: .85rem; color: #c62828; margin-bottom: 1.25rem; }
    .form-hint { font-size: .75rem; color: #aaa; margin-top: .15rem; }
    .current-file { display: flex; align-items: center; gap: .5rem; padding: .55rem .85rem; background: #f5f0e8; border: 1px solid #e8dcc8; border-radius: 8px; font-size: .82rem; color: #555; margin-top: .3rem; }
    .current-file a { color: #2d5a27; text-decoration: none; }
    .current-file a:hover { text-decoration: underline; }
    .btn-submit { padding: .65rem 1.5rem; background: #2d5a27; color: #fff; border: none; border-radius: 8px; font-size: .92rem; font-weight: 600; cursor: pointer; transition: background .2s; }
    .btn-submit:hover { background: #5a8a4a; }
    .btn-cancel { padding: .65rem 1rem; background: transparent; color: #666; border: 1px solid #ddd; border-radius: 8px; font-size: .88rem; cursor: pointer; text-decoration: none; margin-left: .5rem; }
    .breadcrumb { font-size: .8rem; color: #888; margin-bottom: .75rem; }
    .breadcrumb a { color: #2d5a27; text-decoration: none; }
    .stats-bar { display: flex; gap: 1.5rem; margin-bottom: 1.25rem; }
    .stat-pill { font-size: .8rem; color: #888; background: #f5f0e8; padding: .3rem .75rem; border-radius: 20px; }
    .stat-pill strong { color: #2d5a27; }
  </style>
</head>
<body>
<div class="app">
  <aside class="sidebar">
    <h2>Admin Panel</h2>
    <nav>
      <a href="/admin">Dashboard</a>
      <a href="/admin/library" class="active">Library</a>
    </nav>
  </aside>

  <main class="main">
    <header class="header">
      <h1>Edit Library Item</h1>
    </header>

    <section class="card">
      <p class="breadcrumb"><a href="/admin">Admin</a> › <a href="/admin/library">Library</a> › Edit</p>
      <h2 style="margin-bottom:.5rem">Edit Item</h2>

      <div class="stats-bar">
        <span class="stat-pill">Views: <strong><%= item.views %></strong></span>
        <span class="stat-pill">Downloads: <strong><%= item.downloads %></strong></span>
        <span class="stat-pill">Added: <strong><%= new Date(item.createdAt).toLocaleDateString('en-IN', {day:'2-digit', month:'short', year:'numeric'}) %></strong></span>
      </div>

      <% if (error) { %>
        <div class="error-box"><strong>Error:</strong> <%= error %></div>
      <% } %>

      <form method="POST" action="/admin/library/edit/<%= item._id %>" enctype="multipart/form-data">
        <div class="form-grid">

          <div class="form-group full">
            <label>Title <span class="required-star">*</span></label>
            <input type="text" name="title" value="<%= item.title %>" required>
          </div>

          <div class="form-group">
            <label>Author</label>
            <input type="text" name="author" value="<%= item.author || '' %>">
          </div>

          <div class="form-group">
            <label>Category</label>
            <input type="text" name="category" value="<%= item.category || '' %>">
          </div>

          <div class="form-group full">
            <label>Description</label>
            <textarea name="description"><%= item.description || '' %></textarea>
          </div>

          <div class="form-group">
            <label>Tags</label>
            <input type="text" name="tags" value="<%= (item.tags || []).join(', ') %>">
            <span class="form-hint">Comma separated</span>
          </div>

          <div class="form-group">
            <label>Publication Year</label>
            <input type="number" name="publicationYear" value="<%= item.publicationYear || '' %>" min="1900" max="<%= new Date().getFullYear() + 1 %>">
          </div>

          <div class="form-group">
            <label>Language</label>
            <input type="text" name="language" value="<%= item.language || 'English' %>">
          </div>

          <div class="form-group">
            <label>Document Type</label>
            <select name="documentType">
              <option value="blog"    <%= item.documentType === 'blog'    ? 'selected' : '' %>>Blog</option>
              <option value="book"    <%= item.documentType === 'book'    ? 'selected' : '' %>>Book</option>
              <option value="journal" <%= item.documentType === 'journal' ? 'selected' : '' %>>Journal</option>
              <option value="report"  <%= item.documentType === 'report'  ? 'selected' : '' %>>Report</option>
            </select>
          </div>

          <div class="form-group">
            <label>File Format</label>
            <select name="fileFormat">
              <option value="">— Select —</option>
              <option value="PDF"  <%= item.fileFormat === 'PDF'  ? 'selected' : '' %>>PDF</option>
              <option value="EPUB" <%= item.fileFormat === 'EPUB' ? 'selected' : '' %>>EPUB</option>
              <option value="DOC"  <%= item.fileFormat === 'DOC'  ? 'selected' : '' %>>DOC</option>
            </select>
          </div>

          <div class="form-group">
            <label>Availability</label>
            <select name="availability">
              <option value="full"       <%= item.availability === 'full'       ? 'selected' : '' %>>Full Access</option>
              <option value="preview"    <%= item.availability === 'preview'    ? 'selected' : '' %>>Preview Only</option>
              <option value="restricted" <%= item.availability === 'restricted' ? 'selected' : '' %>>Restricted</option>
            </select>
          </div>

          <div class="form-group full">
            <label>Replace File (leave blank to keep existing)</label>
            <input type="file" name="file" accept=".pdf,.epub,.doc,.docx">
            <% if (item.fileUrl) { %>
              <div class="current-file">
                Current: <a href="<%= item.fileUrl %>" target="_blank"><%= item.fileUrl %></a>
              </div>
            <% } %>
            <input type="hidden" name="existingFileUrl" value="<%= item.fileUrl || '' %>">
          </div>

          <div class="form-group full">
            <label>External File URL (optional)</label>
            <input type="text" name="fileUrl" value="<%= item.fileUrl || '' %>" placeholder="https://example.com/document.pdf">
            <span class="form-hint">Overridden if a new file is uploaded above</span>
          </div>

          <div class="form-group full">
            <div class="checkbox-row">
              <input type="checkbox" name="isDownloadable" id="isDownloadable" <%= item.isDownloadable ? 'checked' : '' %>>
              <label for="isDownloadable" style="text-transform:none;letter-spacing:0;font-size:.9rem;color:#333;">Allow users to download this file</label>
            </div>
          </div>

        </div>

        <div style="margin-top:1.5rem;display:flex;align-items:center">
          <button type="submit" class="btn-submit">Save Changes</button>
          <a href="/admin/library" class="btn-cancel">Cancel</a>
        </div>
      </form>
    </section>
  </main>
</div>
</body>
</html>
