<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <title>Users – Admin</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/style.css" />
  <style>
    .page-topbar { display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:1rem; margin-bottom:1.5rem; }
    .search-form { display:flex; gap:.5rem; }
    .search-form input {
      padding: .45rem .85rem;
      border: 1px solid #ddd;
      border-radius: 7px;
      font-size: .85rem;
      font-family: inherit;
      color: #333;
      width: 240px;
    }
    .search-form input:focus { outline: none; border-color: #1c1430; }
    .btn-search {
      padding: .45rem 1rem;
      background: #1c1430;
      color: #fff;
      border: none;
      border-radius: 7px;
      font-size: .85rem;
      font-weight: 600;
      cursor: pointer;
      font-family: inherit;
      transition: background .2s;
    }
    .btn-search:hover { background: #e8701a; }
    .btn-clear {
      padding: .45rem .85rem;
      background: #fff;
      color: #555;
      border: 1px solid #ddd;
      border-radius: 7px;
      font-size: .85rem;
      cursor: pointer;
      text-decoration: none;
      font-family: inherit;
    }

    .users-table { width:100%; border-collapse:collapse; font-size:.86rem; }
    .users-table th {
      background: #f5f0e8;
      padding: .65rem 1rem;
      text-align: left;
      font-size: .72rem;
      letter-spacing: .08em;
      text-transform: uppercase;
      color: #666;
      border-bottom: 2px solid #e8dcc8;
    }
    .users-table td { padding: .7rem 1rem; border-bottom: 1px solid #eee; vertical-align: middle; color: #444; }
    .users-table tr:hover td { background: #fafafa; }

    .user-name  { font-weight: 600; color: #1c1430; }
    .user-email { font-size: .8rem; color: #888; margin-top: .1rem; }
    .user-org   { font-size: .78rem; color: #aaa; }

    .active-dot {
      display: inline-block;
      width: 7px; height: 7px;
      border-radius: 50%;
      background: #2e7d32;
      margin-right: .35rem;
    }

    .stat-cards { display:flex; gap:1rem; margin-bottom:1.5rem; flex-wrap:wrap; }
    .stat-card {
      background: #fff;
      border: 1px solid #eee;
      border-radius: 10px;
      padding: .85rem 1.25rem;
      min-width: 140px;
    }
    .stat-card .num { font-size: 1.6rem; font-weight: 700; color: #1c1430; line-height: 1; }
    .stat-card .lbl { font-size: .72rem; letter-spacing: .07em; text-transform: uppercase; color: #aaa; margin-top: .25rem; }

    .pagination { display:flex; gap:.4rem; margin-top:1.25rem; }
    .pag-btn { padding:.35rem .75rem; border:1px solid #ddd; border-radius:6px; background:#fff; color:#333; font-size:.83rem; text-decoration:none; }
    .pag-btn.active { background:#1c1430; border-color:#1c1430; color:#fff; }
    .pag-btn.disabled { opacity:.35; pointer-events:none; }

    .empty-row td { text-align:center; color:#aaa; padding:2.5rem; font-style:italic; }
    .truncate { max-width:180px; overflow:hidden; text-overflow:ellipsis; white-space:nowrap; }
  </style>
</head>
<body>
<div class="app">
  <aside class="sidebar">
    <h2>Admin Panel</h2>
    <nav>
      <a href="/admin">Dashboard</a>
      <a href="/admin/users" class="active">Users</a>
      <a href="/admin/elibrary">eLibrary</a>
    </nav>
  </aside>

  <main class="main">
    <header class="header"><h1>Registered Users</h1></header>

    <!-- Stats -->
    <div class="stat-cards">
      <div class="stat-card">
        <div class="num"><%= total %></div>
        <div class="lbl">Total Users</div>
      </div>
    </div>

    <section class="card">
      <div class="page-topbar">
        <div>
          <h2>All Users</h2>
          <p style="font-size:.82rem;color:#888;margin-top:.2rem">
            <%= total %> registered<% if (search) { %> · filtered by "<%= search %>"<% } %>
          </p>
        </div>
        <form class="search-form" method="GET" action="/admin/users">
          <input type="text" name="search" value="<%= search %>" placeholder="Search name, email, org…">
          <button type="submit" class="btn-search">Search</button>
          <% if (search) { %><a href="/admin/users" class="btn-clear">Clear</a><% } %>
        </form>
      </div>

      <div style="overflow-x:auto">
        <table class="users-table">
          <thead>
            <tr>
              <th>#</th>
              <th>Name & Email</th>
              <th>Phone</th>
              <th>Organization</th>
              <th>Last Login</th>
              <th>Joined</th>
            </tr>
          </thead>
          <tbody>
            <% if (users.length === 0) { %>
              <tr class="empty-row"><td colspan="6">No users found.</td></tr>
            <% } %>
            <% users.forEach((user, i) => { %>
            <tr>
              <td style="color:#aaa;font-size:.78rem"><%= ((page - 1) * 20) + i + 1 %></td>
              <td>
                <div class="user-name"><span class="active-dot"></span><%= user.name %></div>
                <div class="user-email"><%= user.email %></div>
              </td>
              <td class="user-org"><%= user.phone || '—' %></td>
              <td class="truncate user-org" title="<%= user.organization %>"><%= user.organization || '—' %></td>
              <td style="font-size:.78rem;color:#aaa">
                <%= user.lastLogin ? new Date(user.lastLogin).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) : 'Never' %>
              </td>
              <td style="font-size:.78rem;color:#aaa">
                <%= new Date(user.createdAt).toLocaleDateString('en-IN',{day:'2-digit',month:'short',year:'numeric'}) %>
              </td>
            </tr>
            <% }) %>
          </tbody>
        </table>
      </div>

      <% if (totalPages > 1) { %>
        <div class="pagination">
          <a href="?page=<%= page-1 %><%= search ? '&search='+search : '' %>" class="pag-btn <%= page<=1?'disabled':'' %>">‹ Prev</a>
          <% for(let p=1;p<=totalPages;p++){ %>
            <a href="?page=<%= p %><%= search ? '&search='+search : '' %>" class="pag-btn <%= p===page?'active':'' %>"><%= p %></a>
          <% } %>
          <a href="?page=<%= page+1 %><%= search ? '&search='+search : '' %>" class="pag-btn <%= page>=totalPages?'disabled':'' %>">›</a>
        </div>
      <% } %>
    </section>
  </main>
</div>
</body>
</html>
