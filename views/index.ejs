    <style>
  :root {
    --primary: <%= colors.primary %>;

    --secondary: <%= colors.secondary %>;
    --other: <%= colors.other %>;
  }
</style>



    <link rel="stylesheet" href="/css/SBU.css">
  
    <link rel="stylesheet" href="/css/style.css" >
    <link rel="stylesheet" href="/css/navbar.css" >

  </head>
  <body>
    <div class="page">

      <!-- NAVBAR -->
       <header class="navbar" id="mainNavbar">
  <div class="navbar-inner">

    <!-- Logo -->
    <a href="/" class="nav-logo">
      <div class="logo-mark"><%= logo.logoMark %></div>
      <div class="logo-text">
        <span><%= logo.logoTextTop %></span>
        <span><%= logo.logoTextBottom %></span>
      </div>
    </a>

    <!-- Desktop links -->
    <ul class="nav-links">
      <li><a href="#home">Home</a></li>
      <li><a href="#info">Info</a></li>
      <li><a href="#events">Events</a></li>
      <!-- <li><a href="/library">Library</a></li> -->
      <a href="/elibrary">eLibrary</a>
      <li><a href="/contact">Contact</a></li>
    </ul>

    <!-- Desktop CTA -->
    <a href="#events" class="nav-cta">Get Tickets</a>

    <!-- Hamburger (mobile only) -->
    <button class="nav-hamburger" id="navHamburger" aria-label="Toggle menu" aria-expanded="false">☰</button>

  </div>
</header>

<!-- Mobile drawer — immediately after </header>, outside it -->
<div class="nav-drawer" id="navDrawer">
  <div class="nav-drawer-inner">
    <a href="#home">Home</a>
    <a href="#info">Info</a>
    <a href="#events">Events</a>
    <!-- <a href="/library">Library</a> -->
    <a href="/elibrary">eLibrary</a>
    <a href="/contact">Contact</a>
    <a href="#events" class="drawer-cta">Get Tickets</a>
  </div>
</div>

  

      <!-- HERO -->
      <section id="home" class="hero">
        <div class="hero-inner">
          <div>
            <!-- <div class="hero-eyebrow">Renewable Energy</div> -->
             <div class="hero-eyebrow">
  <%= titles.heroEyebrow %>
</div>
            <!-- <div class="hero-title-main">GREEN TECH<br>REVOLUTION</div> -->
            <div class="hero-title-main"> <%= titles.title %> </div>
            <!-- <div class="hero-subtitle">sustainable<br/>business union</div> -->
            <div class="hero-subtitle"><%= titles.subTitle %> </div>
        
            <div class="hero-url">
              <a href="{{<%= titles.heroUrl %>}"> <%= titles.heroUrl %></a>
  
</div>

          </div>

          <div class="hero-right">
            <div class="hero-card">
              <div class="hero-card-inner">
                <div class="hex"></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- UPCOMING EVENTS -->
    <section id="events" class="section section-gray">
  <div class="wrapper">
    <div class="two-column">

      <!-- LEFT: COL CARD -->
      <div class="col-card">

        <div class="col-header">
          <div class="megaphone-icon">
            <i class="fa-solid fa-bullhorn"></i>
          </div>

          <span class="label-pill">
            <%= colCard?.label || "Circular Economy" %>
          </span>
        </div>

        <h2 class="col-heading">
          <%= colCard?.heading || "WHO'S COMING TO TOWN?" %>
        </h2>

        <p class="col-description">
          <%= colCard?.description || "Stay updated with our latest events" %>
        </p>

        <!-- IMAGE / CAROUSEL -->
        <div class="col-card-illustration">

          <% if (colCard?.images && colCard.images.length > 0) { %>

            <div id="colCardCarousel" class="carousel slide">

              <div class="carousel-inner">

                <% colCard.images.forEach((img, index) => { %>
                  <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                    <img src="<%= img %>" alt="col-card image" class="col-img">
                  </div>
                <% }) %>

              </div>

              <% if (colCard.images.length > 1) { %>
                <button class="carousel-control-prev" type="button" data-bs-target="#colCardCarousel" data-bs-slide="prev">
                  <span class="carousel-control-prev-icon custom-arrow"></span>
                </button>

                <button class="carousel-control-next" type="button" data-bs-target="#colCardCarousel" data-bs-slide="next">
                  <span class="carousel-control-next-icon custom-arrow"></span>
                </button>
              <% } %>

            </div>

          <% } else { %>

            <div class="placeholder">
              No image available
            </div>

          <% } %>

        </div>

      </div>

      <!-- RIGHT: EVENTS PANEL -->
      <div class="events-panel">

        <div class="events-header">
          <h3>Upcoming Acts</h3>
          <span class="events-sub">WHO'S COMING TO TOWN?</span>
        </div>

        <div class="events-list">

          <% if (!events || events.length === 0) { %>

            <div class="empty-state">
              No upcoming events
            </div>

          <% } else { %>

            <% events.forEach(event => { %>

              <div class="event-row">

                <div class="event-info">

                  <div class="event-date">
                    <%= event.date.toDateString() %> • <%= event.time %>
                  </div>

                  <div class="event-title">
                    <%= event.title %>
                  </div>

                  <div class="event-meta">
                    <span><strong>Speakers:</strong> <%= event.artists %></span>
                    <span><strong>Location:</strong> <%= event.location %></span>
                  </div>

                </div>

                <button class="btn-light" style="color:black">Buy Tickets</button>

              </div>

            <% }) %>

          <% } %>

        </div>

        <button class="btn-light btn-block" style = "color:black">See All Events</button>

      </div>

    </div>
  </div>
</section>

      <!-- VIDEO -->
      <section class="video-section" id="info">
        <div class="video-frame">
          <!-- <div class="video-placeholder">
            Video Placeholder (YouTube embed here)
          </div> -->
          <div class="video-placeholder">
  <% if (video?.videoUrl) { %>
    <iframe 
      width="100%" 
      height="100%" 
      src="<%= video.videoUrl %>" 
      frameborder="0" 
      allowfullscreen>
    </iframe>
  <% } else { %>
    <p>No video available</p>
  <% } %>
</div>
        </div>
      </section>

      <!-- ABOUT / GREEN CONSORTIUM -->
<section class="about-section">
  <div class="wrapper">
    <div class="about-grid">

      <!-- LEFT: CAROUSEL -->
      <div class="about-photo">

        <% if (about?.images && about.images.length > 0) { %>

          <div id="aboutCarousel" class="carousel slide">

            <div class="carousel-inner">

              <% about.images.forEach((img, index) => { %>
                <div class="carousel-item <%= index === 0 ? 'active' : '' %>">
                  <img src="<%= img %>" 
                       class="d-block w-100"
                       style="height:260px; object-fit:cover;">
                </div>
              <% }) %>

            </div>

            <button class="carousel-control-prev" type="button" data-bs-target="#aboutCarousel" data-bs-slide="prev">
              <span class="carousel-control-prev-icon"></span>
            </button>

            <button class="carousel-control-next" type="button" data-bs-target="#aboutCarousel" data-bs-slide="next">
              <span class="carousel-control-next-icon"></span>
            </button>

          </div>

        <% } else { %>

          <div class="placeholder">No images available</div>

        <% } %>

      </div>

      <!-- RIGHT: TEXT -->
      <div class="about-card">
        <h3><%= about?.title || "ABOUT US" %></h3>
        <p><%= about?.description || "No description available" %></p>
      </div>

    </div>
  </div>
</section>


      <!-- THE DEAL -->
      <section class="deal-section">
        <div class="deal-inner">
          <div class="deal-header">
            <div class="deal-megaphone">
              <i class="fa-solid fa-bullhorn"></i>
            </div>
            <div class="deal-label">Circular Economy</div>
            <div class="deal-pills">
              <span class="deal-pill">Everything you need</span>
              <span class="deal-pill">To know</span>
            </div>
            <h2 class="deal-title">The Deal</h2>
          </div>

          <div class="deal-grid">
            <div class="deal-card">
              <h4>Expert Guidance</h4>
