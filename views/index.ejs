              </p>

              <div class="checkbox-row">
                <input type="checkbox" id="newsletter-check" />
                <label for="newsletter-check">
                  Yes, subscribe me to your newsletter.
                </label>
              </div>

              <form class="newsletter-form">
                <input type="email" placeholder="Email*" required />
                <button type="submit">Subscribe now</button>
              </form>
            </div>

            <div class="contact-card">
              <h3>Questions? Contact</h3>
              <div class="contact-line">
                <div class="contact-label">Email</div>
                <div>info@sustainablebusinessunion.com</div>
              </div>
              <div class="contact-line">
                <div class="contact-label">Address</div>
                <div>Canary Wharf, London</div>
              </div>
              <div class="contact-line">
                <div class="contact-label">Phone</div>
                <div>+44 7770 264192</div>
              </div>
            </div>
          </div>

        </div>
      </section>

      <footer>
        <div class="wrapper">
          <span> 
          <a href="/privacy">

          &copy; 2025 Sustainable Business Union. Privacy Policy
            </a>
          </span>
          
          <span><a href="/terms">Terms & Conditions</a></span>
        </div>
      </footer>
      <footer>

    </div>



<script>
document.addEventListener("DOMContentLoaded", () => {

  const track = document.querySelector(".carousel-track");
  const slides = document.querySelectorAll(".slide");

  let index = 0;

  function updateSlide() {
    track.style.transform = `translateX(-${index * 100}%)`;
  }

  // 🔥 FORCE INITIAL POSITION
  setTimeout(updateSlide, 50);

  document.querySelector(".next").onclick = () => {
    index = (index + 1) % slides.length;
    updateSlide();
  };

  document.querySelector(".prev").onclick = () => {
    index = (index - 1 + slides.length) % slides.length;
    updateSlide();
  };

});
</script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
<script src="/js/navbar.js" defer></script>
